ADMIN_PASSWORD=troque-esta-senha
ADMIN_SESSION_SECRET=gere-uma-string-aleatoria-com-32-caracteres-ou-mais
# Usada pelo botao "Buscar dados" no admin de produtos (importar produto por link)
# Pegue gratis em https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Blob Store PUBLICO separado do BLOB_READ_WRITE_TOKEN (que e privado, guarda o catalogo).
# Criado via `vercel blob create-store <nome> --access public`, conectado ao projeto
# manualmente no dashboard da Vercel com esse nome de variavel.
BLOB_IMAGES_READ_WRITE_TOKEN=vercel_blob_rw_...
